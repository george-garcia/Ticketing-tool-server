# ── Server ─────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# ── Database (Postgres) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://ticketing:ticketing_dev@localhost:5432/ticketing

# ── Auth ───────────────────────────────────────────────────────────────────
# AUTH_MODE=cognito : verify AWS Cognito ID tokens against the User Pool (production).
# AUTH_MODE=dev     : accept locally-signed HS256 tokens so the API runs without AWS.
AUTH_MODE=dev
DEV_AUTH_SECRET=dev-only-secret-change-me

# Required when AUTH_MODE=cognito:
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Bootstrap admins: comma-separated emails always granted the admin role on login,
# regardless of Cognito groups or their stored role. Use this to seed the first admin
# (roles are otherwise managed in-app after a user's first login).
# e.g. ADMIN_EMAILS=recruiter@demo.com,you@example.com
ADMIN_EMAILS=
